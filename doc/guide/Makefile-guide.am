	$(GUIDE_ADOC_FILES) \
	$(NULL)

noinst_DATA += \
	doc/guide/html/cockpit-guide.html \
	$(NULL)

render-docs: $(GUIDE_ADOC_FILES)
	mkdir -p doc/guide/output/html
	asciidoctor -a cockpit-version=$(VERSION) -b html5 -D doc/guide/output/html doc/guide/cockpit-guide.adoc

CLEAN_LOCAL_TARGETS += clean-guide
clean-guide:
	rm -rf doc/guide/output/html

INSTALL_DATA_LOCAL_TARGETS += install-guide
install-guide:
	mkdir -p $(DESTDIR)$(htmldir)
	$(INSTALL_DATA) doc/guide/output/html/* $(DESTDIR)$(htmldir)

UNINSTALL_LOCAL_TARGETS += uninstall-guide
uninstall-guide:
	rm -rf $(DESTDIR)$(htmldir)

