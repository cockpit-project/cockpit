[Unit]
Description=Cockpit Web Service http instance
BindsTo=cockpit.service
Documentation=man:cockpit-ws(8)
Requires=cockpit-session.socket cockpit-session-socket-owner.service
After=cockpit-session.socket cockpit-session-socket-owner.service

[Service]
ExecStart=@libexecdir@/cockpit-ws --no-tls --port=0
User=@wsinstanceuser@
Group=@wsinstancegroup@
SupplementaryGroups=cockpit-session-socket
